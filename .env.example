# API (required by src/services/api.ts)
# Use full URL including scheme, e.g. https://api.example.com
NEXT_PUBLIC_API_BASE_URL=
# Optional: server-only base URL (no NEXT_PUBLIC_ prefix) — preferred for NextAuth server authorize/refresh
# API_BASE_URL=

# NextAuth (required for session)
# Must match how you open the app (scheme + host + port), e.g. http://localhost:3000 — not http://127.0.0.1:3000 if you use localhost
NEXTAUTH_URL=
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=
